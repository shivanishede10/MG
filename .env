# ============================================================
#  MediGlow — Frontend Environment Variables (Vite)
# ============================================================
# IMPORTANT: Do NOT commit this file to version control if it
# contains real secrets. Add .env to your .gitignore.

# Backend API base URL.
# Leave blank (or remove) to auto-detect using window.location.hostname
# during local development. Set this to your production domain when deploying.
# Example for production: VITE_API_URL=https://api.yourdomain.com/api
VITE_API_URL=
